{
  "manifest_version": "1.2",
  "claude_code_version": "2.1.77",
  "last_docs_sync": "2026-03-17T00:00:00Z",
  "schemas": {
    "skill_frontmatter": {
      "required": [],
      "recommended": [
        "description"
      ],
      "optional": [
        "name",
        "description",
        "allowed-tools",
        "model",
        "context",
        "agent",
        "hooks",
        "argument-hint",
        "disable-model-invocation",
        "user-invocable"
      ],
      "validation": {
        "name": {
          "max_length": 64,
          "pattern": "^[a-z0-9-]+$",
          "description": "lowercase letters, numbers, hyphens only"
        },
        "description": {
          "max_length": 1024,
          "no_xml_tags": true
        }
      },
      "variables": [
        "$ARGUMENTS",
        "$ARGUMENTS[N]",
        "$N",
        "${CLAUDE_SESSION_ID}",
        "${CLAUDE_SKILL_DIR}"
      ],
      "dynamic_context": "!`command`"
    },
    "agent_frontmatter": {
      "required": [
        "name",
        "description"
      ],
      "optional": [
        "tools",
        "disallowedTools",
        "model",
        "color",
        "hooks",
        "permissionMode",
        "skills",
        "maxTurns",
        "mcpServers",
        "memory",
        "background",
        "isolation"
      ],
      "plugin_restrictions": {
        "not_supported": ["hooks", "mcpServers", "permissionMode"],
        "reason": "Security: plugin agents cannot override hook/permission/MCP configuration"
      }
    },
    "command_frontmatter": {
      "required": [],
      "optional": [
        "description",
        "allowed-tools",
        "model",
        "argument-hint"
      ],
      "note": "Commands merged into skills — both .claude/commands/foo.md and .claude/skills/foo/SKILL.md create /foo"
    },
    "plugin_manifest": {
      "required": [
        "name"
      ],
      "optional": [
        "description",
        "version",
        "author",
        "keywords",
        "repository",
        "license",
        "homepage",
        "commands",
        "agents",
        "skills",
        "hooks",
        "mcpServers",
        "outputStyles",
        "lspServers"
      ]
    },
    "marketplace_manifest": {
      "required": ["name", "owner", "plugins"],
      "required_owner_fields": ["name"],
      "optional_owner_fields": ["email"],
      "optional": ["metadata"],
      "metadata_fields": ["description", "version", "pluginRoot"],
      "reserved_names": [
        "claude-code-marketplace",
        "claude-code-plugins",
        "claude-plugins-official",
        "anthropic-marketplace",
        "anthropic-plugins",
        "agent-skills",
        "knowledge-work-plugins",
        "life-sciences"
      ]
    },
    "marketplace_plugin_entry": {
      "required": ["name", "source"],
      "optional": [
        "description",
        "version",
        "author",
        "homepage",
        "repository",
        "license",
        "keywords",
        "category",
        "tags",
        "strict",
        "commands",
        "agents",
        "skills",
        "hooks",
        "mcpServers",
        "outputStyles",
        "lspServers"
      ],
      "field_types": {
        "author": {"type": "object", "required": ["name"], "optional": ["email"]},
        "keywords": {"type": "array"},
        "homepage": {"type": "string"},
        "repository": {"type": "string"},
        "license": {"type": "string"}
      },
      "source_types": {
        "relative_path": {"format": "string starting with ./", "disallowed": ["../"]},
        "github": {"fields": {"repo": "required", "ref": "optional", "sha": "optional"}},
        "url": {"fields": {"url": "required", "ref": "optional", "sha": "optional"}},
        "git-subdir": {"fields": {"url": "required", "path": "required", "ref": "optional", "sha": "optional"}},
        "npm": {"fields": {"package": "required", "version": "optional", "registry": "optional"}}
      },
      "deprecated_fields": {
        "path": {
          "replacement": "source",
          "severity": "warning"
        }
      }
    },
    "hooks": {
      "events": {
        "SessionStart": {
          "can_block": false,
          "has_matcher": true,
          "matcher_values": ["startup", "resume", "clear", "compact"]
        },
        "UserPromptSubmit": {
          "can_block": true,
          "has_matcher": false
        },
        "PreToolUse": {
          "can_block": true,
          "has_matcher": true,
          "matcher_values": "tool_name"
        },
        "PermissionRequest": {
          "can_block": true,
          "has_matcher": true,
          "matcher_values": "tool_name"
        },
        "PostToolUse": {
          "can_block": false,
          "has_matcher": true,
          "matcher_values": "tool_name"
        },
        "PostToolUseFailure": {
          "can_block": false,
          "has_matcher": true,
          "matcher_values": "tool_name"
        },
        "Notification": {
          "can_block": false,
          "has_matcher": true,
          "matcher_values": ["permission_prompt", "idle_prompt", "auth_success", "elicitation_dialog"]
        },
        "SubagentStart": {
          "can_block": false,
          "has_matcher": true,
          "matcher_values": "agent_type"
        },
        "SubagentStop": {
          "can_block": true,
          "has_matcher": true,
          "matcher_values": "agent_type"
        },
        "Stop": {
          "can_block": true,
          "has_matcher": false
        },
        "PreCompact": {
          "can_block": false,
          "has_matcher": true,
          "matcher_values": ["manual", "auto"]
        },
        "PostCompact": {
          "can_block": false,
          "has_matcher": true,
          "matcher_values": ["manual", "auto"]
        },
        "SessionEnd": {
          "can_block": false,
          "has_matcher": true,
          "matcher_values": ["clear", "logout", "prompt_input_exit", "bypass_permissions_disabled", "other"]
        },
        "TeammateIdle": {
          "can_block": true,
          "has_matcher": false
        },
        "TaskCompleted": {
          "can_block": true,
          "has_matcher": false
        },
        "InstructionsLoaded": {
          "can_block": false,
          "has_matcher": false
        },
        "ConfigChange": {
          "can_block": true,
          "has_matcher": true,
          "matcher_values": ["user_settings", "project_settings", "local_settings", "policy_settings", "skills"]
        },
        "WorktreeCreate": {
          "can_block": true,
          "has_matcher": false
        },
        "WorktreeRemove": {
          "can_block": false,
          "has_matcher": false
        },
        "Elicitation": {
          "can_block": true,
          "has_matcher": false
        },
        "ElicitationResult": {
          "can_block": true,
          "has_matcher": false
        },
        "Setup": {
          "can_block": false,
          "has_matcher": true,
          "matcher_values": ["--init", "--init-only", "--maintenance"]
        }
      },
      "handler_fields": {
        "type": {
          "values": ["command", "prompt", "agent", "http"],
          "required": false,
          "default": "command"
        },
        "command": {
          "required_for": "command"
        },
        "prompt": {
          "required_for": ["prompt", "agent"]
        },
        "url": {
          "required_for": "http"
        },
        "headers": {
          "type": "object",
          "used_by": "http"
        },
        "allowedEnvVars": {
          "type": "array",
          "used_by": "http",
          "description": "Environment variables to include in request"
        },
        "timeout": {
          "type": "number"
        },
        "statusMessage": {
          "type": "string"
        },
        "once": {
          "type": "boolean"
        },
        "async": {
          "type": "boolean"
        },
        "model": {
          "values": ["sonnet", "opus", "haiku"]
        }
      },
      "output_format": "hookSpecificOutput",
      "valid_models": [
        "sonnet",
        "opus",
        "haiku"
      ],
      "valid_model_ids": [
        "claude-opus-4-6",
        "claude-sonnet-4-6",
        "claude-haiku-4-5-20251001"
      ],
      "valid_colors": [
        "blue",
        "cyan",
        "green",
        "yellow",
        "magenta",
        "red"
      ],
      "plugin_format": {
        "requires_hooks_wrapper": true,
        "optional_description": true
      }
    },
    "permission_modes": {
      "values": ["default", "acceptEdits", "dontAsk", "bypassPermissions", "plan"],
      "descriptions": {
        "default": "Standard permission prompts",
        "acceptEdits": "Auto-approve file edits, prompt for others",
        "dontAsk": "Auto-approve most actions",
        "bypassPermissions": "Skip all permission prompts (dangerous)",
        "plan": "Require plan approval before execution"
      }
    },
    "model_values": {
      "short": ["sonnet", "opus", "haiku"],
      "full_ids": ["claude-opus-4-6", "claude-sonnet-4-6", "claude-haiku-4-5-20251001"],
      "special": ["inherit"]
    }
  },
  "deprecations": [
    {
      "pattern": "$TOOL_INPUT",
      "replacement": "stdin JSON parsed with jq",
      "since": "2.0.0",
      "severity": "warning"
    },
    {
      "pattern": "$TOOL_OUTPUT",
      "replacement": "stdin JSON parsed with jq",
      "since": "2.0.0",
      "severity": "warning"
    },
    {
      "pattern": "$TOOL_NAME",
      "replacement": "stdin JSON parsed with jq",
      "since": "2.0.0",
      "severity": "warning"
    },
    {
      "pattern": "hook_type",
      "replacement": "hook_event_name",
      "since": "2.1.0",
      "severity": "warning"
    },
    {
      "pattern": "decision.*block",
      "replacement": "permissionDecision: deny",
      "since": "2.1.0",
      "severity": "error"
    },
    {
      "pattern": "docs.anthropic.com",
      "replacement": "code.claude.com",
      "since": "2.1.0",
      "severity": "warning"
    },
    {
      "pattern": "$ARGUMENTS.0",
      "replacement": "$ARGUMENTS[0] (indexed bracket syntax)",
      "since": "2.1.19",
      "severity": "warning"
    },
    {
      "pattern": "Task tool",
      "replacement": "Agent tool (Task still works as alias)",
      "since": "2.1.63",
      "severity": "warning"
    },
    {
      "pattern": "PreToolUse top-level decision/reason",
      "replacement": "hookSpecificOutput.permissionDecision",
      "since": "2.1.0",
      "severity": "error"
    },
    {
      "pattern": "Agent resume param",
      "replacement": "SendMessage({to: agentId})",
      "since": "2.1.77",
      "severity": "warning"
    }
  ],
  "canonical_urls": {
    "skills": "https://code.claude.com/docs/en/skills",
    "best_practices": "https://platform.claude.com/docs/en/agents-and-tools/agent-skills/best-practices",
    "subagents": "https://code.claude.com/docs/en/sub-agents",
    "hooks": "https://code.claude.com/docs/en/hooks",
    "hooks_guide": "https://code.claude.com/docs/en/hooks-guide",
    "plugins": "https://code.claude.com/docs/en/plugins",
    "plugins_reference": "https://code.claude.com/docs/en/plugins-reference",
    "plugin_marketplaces": "https://code.claude.com/docs/en/plugin-marketplaces",
    "agent_teams": "https://code.claude.com/docs/en/agent-teams",
    "scheduled_tasks": "https://code.claude.com/docs/en/scheduled-tasks",
    "settings": "https://code.claude.com/docs/en/settings",
    "docs_index": "https://code.claude.com/docs/llms.txt"
  }
}
